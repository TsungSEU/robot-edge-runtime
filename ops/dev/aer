#!/bin/bash
#
# aer - Aurora Edge Runtime Control Script
# Usage: aer {start|stop|restart|status|logs} [mode]
#

set -e

# Project directory - handle symlink case
AER_SCRIPT="${BASH_SOURCE[0]}"

# If script is a symlink, follow it to get the real path
if [ -L "$AER_SCRIPT" ]; then
    # Get the directory containing the symlink
    SYMLINK_DIR="$(dirname "$AER_SCRIPT")"
    # Get the symlink target
    SYMLINK_TARGET="$(readlink "$AER_SCRIPT")"
    # If target is relative, resolve it relative to symlink's directory
    if [[ "$SYMLINK_TARGET" != /* ]]; then
        AER_SCRIPT="$(cd "$SYMLINK_DIR" && cd "$(dirname "$SYMLINK_TARGET")" && pwd)/$(basename "$SYMLINK_TARGET")"
    else
        AER_SCRIPT="$SYMLINK_TARGET"
    fi
fi

# Get the directory containing the actual script (ops/)
SCRIPT_DIR="$(dirname "$AER_SCRIPT")"

# Project directory is the parent of ops/ directory
PROJECT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
BUILD_DIR="$PROJECT_DIR/build"
PID_DIR="$PROJECT_DIR/.pids"
LOG_DIR="/tmp"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Create PID directory if it doesn't exist
mkdir -p "$PID_DIR"

# Executables
AER_EXEC="$BUILD_DIR/src/aer"

# PID files
AER_PID_FILE="$PID_DIR/aer.pid"

# Modes
MODE="${AER_MODE:-humanoid}"

# Function to log colored messages
log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_debug() {
    echo -e "${BLUE}[DEBUG]${NC} $1"
}

# Function to source environments
source_environments() {
    # Source ROS2 environment
    if [ -f "/opt/ros/humble/setup.bash" ]; then
        source /opt/ros/humble/setup.bash >/dev/null 2>&1
    fi

    # Source project environment
    if [ -f "$PROJECT_DIR/setup.bash" ]; then
        source "$PROJECT_DIR/setup.bash" >/dev/null 2>&1
    fi

    # Set library path
    export LD_LIBRARY_PATH="$BUILD_DIR/src:$LD_LIBRARY_PATH"
}

# Function to check if process is running
is_running() {
    local pid_file=$1
    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")
        if ps -p "$pid" > /dev/null 2>&1; then
            return 0
        else
            rm -f "$pid_file"
            return 1
        fi
    fi
    return 1
}

# Function to wait for service
wait_for_service() {
    local service_name=$1
    local max_wait=${2:-10}
    local count=0

    while [ $count -lt $max_wait ]; do
        if pgrep -f "$service_name" > /dev/null; then
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    return 1
}

# Function to start robot_sim (for development only)
# Note: robot_sim should be started manually when needed
start_robot_sim() {
    log_warn "robot_sim is not managed by aer command"
    log_info "To start robot_sim manually, run:"
    echo "  $BUILD_DIR/src/robot_sim"
    return 0
}

# Function to start aer
start_aer() {
    if is_running "$AER_PID_FILE"; then
        log_warn "AER is already running (PID: $(cat $AER_PID_FILE))"
        return 0
    fi

    log_info "Starting AER (mode: $MODE)..."

    # Check if executable exists
    if [ ! -f "$AER_EXEC" ]; then
        log_error "aer executable not found: $AER_EXEC"
        log_error "Please build the project first: cd $BUILD_DIR && cmake .. && make -j8"
        return 1
    fi

    # Build command
    local cmd=("$AER_EXEC")
    if [ -n "$MODE" ]; then
        cmd+=("--mode" "$MODE")
    fi

    # Start aer in background
    source_environments
    nohup "${cmd[@]}" > "$LOG_DIR/aer.log" 2>&1 &
    local pid=$!
    echo $pid > "$AER_PID_FILE"

    # Wait for process to start
    sleep 2

    if is_running "$AER_PID_FILE"; then
        log_info "AER started successfully (PID: $pid)"
        return 0
    else
        log_error "Failed to start AER"
        return 1
    fi
}

# Function to stop process
stop_process() {
    local name=$1
    local pid_file=$2
    local signal=${3:-TERM}

    if ! is_running "$pid_file"; then
        log_warn "$name is not running"
        return 0
    fi

    local pid=$(cat "$pid_file")
    log_info "Stopping $name (PID: $pid)..."

    # Send signal
    kill -$signal $pid 2>/dev/null || true

    # Wait for process to stop
    local count=0
    while [ $count -lt 10 ]; do
        if ! ps -p $pid > /dev/null 2>&1; then
            rm -f "$pid_file"
            log_info "$name stopped successfully"
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done

    # Force kill if still running
    if ps -p $pid > /dev/null 2>&1; then
        log_warn "$name still running, sending SIGKILL..."
        kill -9 $pid 2>/dev/null || true
        rm -f "$pid_file"
        log_info "$name killed"
    fi
}

# Function to stop robot_sim (not managed by aer)
stop_robot_sim() {
    log_warn "robot_sim is not managed by aer command"
    log_info "To stop robot_sim, use: pkill robot_sim or kill \$(cat .pids/robot_sim.pid)"
    return 0
}

# Function to stop aer
stop_aer() {
    stop_process "aer" "$AER_PID_FILE"
}

# Function to start DCP service
start_all() {
    log_info "Starting Aurora Edge Runtime ..."
    echo ""

    # Start aer
    if ! start_aer; then
        log_error "Failed to start AER"
        return 1
    fi

    echo ""
    log_info "Aurora Edge Runtime started successfully!"
    echo ""
    echo "Services:"
    echo "  - aer:       PID $(cat $AER_PID_FILE)"
    echo ""
    echo "Logs:"
    echo "  - aer:       $LOG_DIR/aer.log"
    echo ""
    log_info "Use 'aer logs aer' to view logs"
    log_info "Use 'aer stop' to stop AER service"
    echo ""
    log_warn "Note: robot_sim is not managed by aer. Start it separately if needed:"
    echo "  $BUILD_DIR/src/robot_sim"
}

# Function to stop DCP service
stop_all() {
    log_info "Stopping Aurora Edge Runtime (AER service) (AER service)..."
    echo ""

    # Stop aer
    stop_aer

    echo ""
    log_info "Aurora Edge Runtime stopped"
}

# Function to show status
show_status() {
    echo "Aurora Edge Runtime (AER) Status:"
    echo ""

    # Check aer
    if is_running "$AER_PID_FILE"; then
        local pid=$(cat "$AER_PID_FILE")
        echo -e "${GREEN}✓${NC} aer:       running (PID: $pid)"
    else
        echo -e "${RED}✗${NC} aer:       stopped"
    fi

    # Check if robot_sim is running (informational only)
    if pgrep -x "robot_sim" > /dev/null; then
        local pid=$(pgrep -x "robot_sim")
        echo -e "${GREEN}✓${NC} robot_sim: running (PID: $pid) ${YELLOW}[not managed by aer]${NC}"
    else
        echo -e "${RED}✗${NC} robot_sim: stopped ${YELLOW}[not managed by aer]${NC}"
    fi

    echo ""
}

# Function to show logs
show_logs() {
    local service=$1

    case "$service" in
        aer)
            if [ -f "$LOG_DIR/aer.log" ]; then
                tail -f "$LOG_DIR/aer.log"
            else
                log_error "aer log not found: $LOG_DIR/aer.log"
            fi
            ;;
        robot_sim)
            log_warn "robot_sim logs are not managed by aer"
            log_info "To view robot_sim logs:"
            echo "  tail -f $LOG_DIR/robot_sim.log"
            return 1
            ;;
        *)
            log_error "Unknown service: $service"
            echo "Available services: aer"
            return 1
            ;;
    esac
}

# Function to restart all services
restart_all() {
    log_info "Restarting Aurora Edge Runtime..."
    echo ""
    stop_all
    echo ""
    sleep 2
    start_all
}

# Function to show usage
show_usage() {
    cat << EOF
Aurora Edge Runtime Control Script

Usage: aer {command} [options]

Commands:
  start              Start AER service
  stop               Stop AER service
  restart            Restart AER service
  status             Show AER service status
  logs [service]     Follow logs (default: aer)

Options:
  --mode <mode>      Set runtime mode (auto or humanoid, default: humanoid)

Environment Variables:
  AER_MODE           Runtime mode (auto or humanoid)

Notes:
  - This script manages only the AER (Aurora Edge Runtime) service
  - robot_sim should be started separately for development/testing:
    $BUILD_DIR/src/robot_sim

Examples:
  aer start                    # Start AER in humanoid mode
  aer start --mode auto        # Start AER in auto mode
  aer stop                     # Stop AER
  aer status                   # Show AER service status
  aer logs aer                 # Follow aer logs
  aer restart                  # Restart AER

  AER_MODE=auto aer start      # Start AER in auto mode using env variable

EOF
}

# Main script logic
case "${1:-}" in
    start)
        shift
        # Parse arguments
        while [[ $# -gt 0 ]]; do
            case $1 in
                --mode)
                    MODE="$2"
                    shift 2
                    ;;
                *)
                    log_error "Unknown option: $1"
                    show_usage
                    exit 1
                    ;;
            esac
        done
        start_all
        ;;
    stop)
        stop_all
        ;;
    restart)
        restart_all
        ;;
    status)
        show_status
        ;;
    logs)
        show_logs "${2:-aer}"
        ;;
    *)
        show_usage
        exit 1
        ;;
esac
