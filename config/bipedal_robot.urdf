<?xml version="1.0"?>
<robot name="bipedal_robot">
  <!-- Base Link (躯干) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Left Leg -->
  <link name="left_hip_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="left_hip_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="left_hip_link"/>
    <origin xyz="0.0 0.1 -0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="5.0"/>
  </joint>

  <link name="left_hip_roll_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="left_hip_roll" type="revolute">
    <parent link="left_hip_link"/>
    <child link="left_hip_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5" upper="0.5" effort="100" velocity="5.0"/>
  </joint>

  <link name="left_upper_leg">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.3"/>
      </geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="left_hip_pitch" type="revolute">
    <parent link="left_hip_roll_link"/>
    <child link="left_upper_leg"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="150" velocity="5.0"/>
  </joint>

  <link name="left_lower_leg">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.3"/>
      </geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="left_knee_pitch" type="revolute">
    <parent link="left_upper_leg"/>
    <child link="left_lower_leg"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="0" effort="150" velocity="5.0"/>
  </joint>

  <link name="left_ankle_link">
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.015"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="left_ankle_pitch" type="revolute">
    <parent link="left_lower_leg"/>
    <child link="left_ankle_link"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.0" effort="50" velocity="5.0"/>
  </joint>

  <link name="left_foot">
    <visual>
      <geometry>
        <box size="0.1 0.06 0.03"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="left_ankle_roll" type="revolute">
    <parent link="left_ankle_link"/>
    <child link="left_foot"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5" upper="0.5" effort="50" velocity="5.0"/>
  </joint>

  <!-- Right Leg -->
  <link name="right_hip_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="right_hip_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="right_hip_link"/>
    <origin xyz="0.0 -0.1 -0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="5.0"/>
  </joint>

  <link name="right_hip_roll_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="right_hip_roll" type="revolute">
    <parent link="right_hip_link"/>
    <child link="right_hip_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5" upper="0.5" effort="100" velocity="5.0"/>
  </joint>

  <link name="right_upper_leg">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.3"/>
      </geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="right_hip_pitch" type="revolute">
    <parent link="right_hip_roll_link"/>
    <child link="right_upper_leg"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="150" velocity="5.0"/>
  </joint>

  <link name="right_lower_leg">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.3"/>
      </geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="right_knee_pitch" type="revolute">
    <parent link="right_upper_leg"/>
    <child link="right_lower_leg"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="0" effort="150" velocity="5.0"/>
  </joint>

  <link name="right_ankle_link">
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.015"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="right_ankle_pitch" type="revolute">
    <parent link="right_lower_leg"/>
    <child link="right_ankle_link"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.0" effort="50" velocity="5.0"/>
  </joint>

  <link name="right_foot">
    <visual>
      <geometry>
        <box size="0.1 0.06 0.03"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_ankle_roll" type="revolute">
    <parent link="right_ankle_link"/>
    <child link="right_foot"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5" upper="0.5" effort="50" velocity="5.0"/>
  </joint>

</robot>
