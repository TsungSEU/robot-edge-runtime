    - Alpha: 1
      Buffer Length: 1
      Class: rviz_default_plugins/Path
      Color: 255; 170; 0
      Enabled: true
      Head Diameter: 0.1
      Head Length: 0.07
      Length: 0.3
      Line Style: Billboards
      Line Width: 0.03
      Name: Robot Trail
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Color: 255; 25; 0
      Pose Style: None
      Radius: 0.02
      Shaft Diameter: 0.05
      Shaft Length: 0.23
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot/trail
