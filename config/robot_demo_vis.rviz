    - Class: rviz_default_plugins/Axes
      Enabled: true
      Length: 1
      Name: Origin
      Radius: 0.10000000149011612
      Reference Frame: odom
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: odom
    Frame Rate: 30
  Name: root
  Tools:
